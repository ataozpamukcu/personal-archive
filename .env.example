# Supabase project settings. Keep the service role key server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public values used only for direct signed Storage uploads in the admin form.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Password used only for /admin/comments moderation.
COMMENTS_ADMIN_PASSWORD=choose-a-long-random-password
